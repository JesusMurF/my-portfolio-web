---
// BlogSection muestra un preview de los 3 posts más recientes en la home.
// getCollection('blog') carga todos los posts validados contra el schema.
// Filtramos drafts, ordenamos por fecha descendente y cogemos los 3 primeros.
// Esto ocurre en build time: es HTML estático, sin JS en cliente.
// Docs: https://docs.astro.build/en/guides/content-collections/#querying-collections

import { getCollection } from 'astro:content';
import BlogCard from '../blog/BlogCard.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section class="border-t border-border-color pt-16 pb-16">
  <p class="text-muted text-sm font-mono mb-3 tracking-widest uppercase">
    Blog
  </p>

  <h2 class="text-2xl font-bold text-fg mb-8">
    Últimas entradas.
  </h2>

  <div class="flex flex-col gap-4">
    {recentPosts.map(post => (
      <BlogCard
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        tags={post.data.tags}
        slug={post.id}
      />
    ))}
  </div>

  <div class="mt-8">
    <a
      href="/blog"
      class="text-sm text-primary hover:underline underline-offset-4 transition-colors"
    >
      Ver todos los posts →
    </a>
  </div>
</section>
