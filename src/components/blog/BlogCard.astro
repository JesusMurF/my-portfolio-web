---
// BlogCard muestra el resumen de un post en forma de card.
// Se usa tanto en la home (BlogSection, 3 posts) como en /blog (todos los posts).
// Props reciben los datos ya procesados desde la página padre.

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

// Formateamos la fecha en español: "24 mar 2026"
// toLocaleDateString con opciones produce un formato legible sin librerías externas.
const formattedDate = date.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block bg-surface rounded-lg p-6 border border-border-color hover:border-primary transition-colors"
>
  <div class="flex items-center gap-3 mb-3">
    <span class="text-xs text-muted font-mono">{formattedDate}</span>
    {tags.length > 0 && (
      <>
        <span class="text-muted text-xs">·</span>
        <div class="flex gap-2 flex-wrap">
          {tags.slice(0, 3).map(tag => (
            <span class="text-xs text-muted font-mono">{tag}</span>
          ))}
        </div>
      </>
    )}
  </div>
  <h3 class="text-fg font-semibold mb-2 group-hover:text-primary transition-colors">
    {title}
  </h3>
  <p class="text-muted text-sm leading-relaxed">{description}</p>
</a>
