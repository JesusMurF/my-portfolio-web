---
// /blog/[...slug] — página de post individual.
//
// getStaticPaths() es obligatorio en páginas con parámetros dinámicos en Astro.
// Le dice al build qué rutas generar. Retorna un array de { params, props } por post.
// Docs: https://docs.astro.build/en/reference/api-reference/#getstaticpaths
//
// entry.render() devuelve { Content, headings }:
// - Content: componente Astro que renderiza el Markdown a HTML
// - headings: array de { depth, slug, text } extraídos automáticamente del Markdown
// Docs: https://docs.astro.build/en/guides/content-collections/#rendering-content

// En Astro 6 con el nuevo Content Layer API (loader: glob), render() es una función
// importada de 'astro:content', no un método del entry. Esto es un cambio respecto a Astro 4.
// Docs: https://docs.astro.build/en/guides/content-collections/#rendering-content
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import BlogHeader from '../../components/blog/BlogHeader.astro';
import BlogToc from '../../components/blog/BlogToc.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(post => !post.data.draft)
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Calculamos prev/next ordenando todos los posts por fecha.
// El post más reciente no tiene "siguiente", el más antiguo no tiene "anterior".
const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<BlogLayout title={post.data.title} description={post.data.description}>
  <BlogHeader
    title={post.data.title}
    date={post.data.date}
    tags={post.data.tags}
  />

  <BlogToc headings={headings} />

  <!-- prose: aplica estilos tipográficos al HTML generado por el Markdown.
       Sin estas clases, el Markdown renderizado no tendría estilos (los h2, p, code, etc.
       heredan solo los estilos base de Tailwind, que resetea todo a unstyled).
       Los definimos directamente en CSS para no depender de @tailwindcss/typography. -->
  <article class="prose-content">
    <Content />
  </article>

  <!-- Navegación prev/next -->
  {(prevPost || nextPost) && (
    <nav class="mt-16 pt-8 border-t border-border-color flex justify-between gap-4">
      <div>
        {prevPost && (
          <a href={`/blog/${prevPost.id}`} class="group flex flex-col gap-1">
            <span class="text-xs text-muted font-mono">← Anterior</span>
            <span class="text-sm text-fg group-hover:text-primary transition-colors">
              {prevPost.data.title}
            </span>
          </a>
        )}
      </div>
      <div class="text-right">
        {nextPost && (
          <a href={`/blog/${nextPost.id}`} class="group flex flex-col gap-1 items-end">
            <span class="text-xs text-muted font-mono">Siguiente →</span>
            <span class="text-sm text-fg group-hover:text-primary transition-colors">
              {nextPost.data.title}
            </span>
          </a>
        )}
      </div>
    </nav>
  )}
</BlogLayout>
